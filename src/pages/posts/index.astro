---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const grouped = new Map<number, typeof posts>();
for (const p of posts) {
  const y = p.data.pubDate.getFullYear();
  if (!grouped.has(y)) grouped.set(y, [] as typeof posts);
  grouped.get(y)!.push(p);
}
const years = [...grouped.keys()].sort((a, b) => b - a);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
---
<BaseLayout title="All posts" description="Every post on blog.brianbaldock.net.">
  <section class="container">
    <h1>All posts</h1>
    {posts.length === 0 && <p class="muted">Nothing published yet.</p>}
    {years.map((year) => (
      <section class="year-block">
        <h2>{year}</h2>
        <ul class="post-list">
          {grouped.get(year)!.map((post) => (
            <li>
              <time datetime={post.data.pubDate.toISOString()} class="subtle date">
                {fmt(post.data.pubDate)}
              </time>
              <a href={`/posts/${post.id}/`}>{post.data.title}</a>
            </li>
          ))}
        </ul>
      </section>
    ))}
  </section>
</BaseLayout>

<style>
  .year-block { margin: 2rem 0; }
  .post-list { list-style: none; padding: 0; margin: 0.5rem 0; }
  .post-list li {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--border);
  }
  .date { white-space: nowrap; }
  @media (max-width: 540px) {
    .post-list li { grid-template-columns: 1fr; gap: 0.15rem; }
  }
</style>
