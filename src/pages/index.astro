---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 5);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<BaseLayout>
  <section class="container hero">
    <h1>Hi, I'm Brian.</h1>
    <p class="lede">
      I work on identity, security, and AI infrastructure. This is where I write
      down the things I learn — usually after I've made the mistake first.
    </p>
    <p>
      You can find longer posts under <a href="/posts/">writing</a>, what I'm
      currently building under <a href="/projects/">projects</a>, or the short
      version under <a href="/about/">about</a>.
    </p>
  </section>

  <section class="container">
    <h2>Recent posts</h2>
    {posts.length === 0 ? (
      <p class="muted">Nothing published yet. Drafts are cooking.</p>
    ) : (
      <ul class="post-list">
        {posts.map((post) => (
          <li>
            <a href={`/posts/${post.id}/`}>
              <h3>{post.data.title}</h3>
              <p class="subtle">
                <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
              </p>
              {post.data.description && <p class="muted">{post.data.description}</p>}
            </a>
          </li>
        ))}
      </ul>
    )}
    <p><a href="/posts/">All posts →</a></p>
  </section>
</BaseLayout>

<style>
  .hero { margin-top: 3rem; margin-bottom: 3rem; }
  .lede { font-size: 1.15rem; color: var(--fg-muted); }
  .post-list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
    display: grid;
    gap: 1rem;
  }
  .post-list li a {
    display: block;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--fg);
    background: var(--bg-elev);
    box-shadow: var(--shadow);
  }
  .post-list li a:hover { border-color: var(--accent); }
  .post-list h3 { margin: 0 0 0.25rem; }
</style>
