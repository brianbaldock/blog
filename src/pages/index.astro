---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const [featured, ...rest] = posts;
const recent = rest.slice(0, 6);
---
<BaseLayout>
  <section class="container-wide hero">
    <p class="eyebrow">Identity · Security · AI infrastructure</p>
    <h1>Hi, I'm Brian.</h1>
    <p class="lede">
      I write down the things I learn — usually after I've made the mistake first.
      Long-form posts on what I'm building, breaking, and defending.
    </p>
  </section>

  {featured && (
    <section class="container-wide">
      <h2 class="section-heading"><span>Featured</span></h2>
      <PostCard
        href={`/posts/${featured.id}/`}
        title={featured.data.title}
        description={featured.data.description}
        pubDate={featured.data.pubDate}
        cover={featured.data.cover}
        coverAlt={featured.data.coverAlt}
        tags={featured.data.tags}
        featured
      />
    </section>
  )}

  {recent.length > 0 && (
    <section class="container-wide">
      <h2 class="section-heading"><span>Recent posts</span></h2>
      <div class="grid">
        {recent.map((post) => (
          <PostCard
            href={`/posts/${post.id}/`}
            title={post.data.title}
            description={post.data.description}
            pubDate={post.data.pubDate}
            cover={post.data.cover}
            coverAlt={post.data.coverAlt}
            tags={post.data.tags}
          />
        ))}
      </div>
      <p class="more"><a href="/posts/">Browse all posts →</a></p>
    </section>
  )}
</BaseLayout>

<style>
  .hero { margin-top: 2.5rem; margin-bottom: 2.5rem; }
  .eyebrow {
    text-transform: uppercase; letter-spacing: 0.08em;
    font-size: 0.78rem; color: var(--accent); margin: 0 0 0.5rem;
  }
  .hero h1 { font-size: clamp(2rem, 5vw, 3rem); margin: 0 0 0.75rem; }
  .lede { font-size: 1.15rem; color: var(--fg-muted); max-width: 56ch; }
  .section-heading {
    display: flex; align-items: center; gap: 1rem;
    margin: 2.5rem 0 1.25rem; font-size: 1rem;
    text-transform: uppercase; letter-spacing: 0.1em; color: var(--fg-muted);
  }
  .section-heading::after {
    content: ''; flex: 1; height: 1px; background: var(--border);
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .more { margin-top: 1.75rem; text-align: right; }
</style>
